{
  "manifest_version": 3,
  "name": "JobCopilot · AI求职智能体",
  "version": "1.8.1",
  "description": "完整 JD 智能筛选 + 人工批准队列 + 三段式自动投递",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_title": "BOSS自动投递" },
  "side_panel": { "default_path": "src/sidepanel.html" },
  "permissions": ["storage", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "*://*.zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://api.xiaomimimo.com/*",
    "https://api.longcat.chat/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.zhipin.com/web/geek/job*", "*://*.zhipin.com/job_detail/*"],
      "js": ["src/selectors.js", "src/job-filters.js", "src/job-detail.js", "src/detail-readiness.js", "src/contact-interstitial.js", "src/content-search.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/web/geek/chat*"],
      "js": ["src/selectors.js", "src/message-bundle.js", "src/image-receipt.js", "src/chat-page-identity.js", "src/content-chat.js"],
      "run_at": "document_idle"
    }
  ]
}
