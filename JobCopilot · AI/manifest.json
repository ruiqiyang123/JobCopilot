{
  "manifest_version": 3,
  "name": "JobCopilot · AI求职智能体",
  "version": "1.0.0",
  "description": "基于 LLM 的智能求职助手：AI 岗位匹配 + 千岗千面招呼语 + 自动投递",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_title": "BOSS自动投递" },
  "side_panel": { "default_path": "src/sidepanel.html" },
  "permissions": ["storage", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "*://*.zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://api.xiaomimimo.com/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.zhipin.com/web/geek/job*"],
      "js": ["src/selectors.js", "src/content-search.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/web/geek/chat*"],
      "js": ["src/selectors.js", "src/content-chat.js"],
      "run_at": "document_idle"
    }
  ]
}
